<?xml version="1.0" encoding="UTF-8"?>
<!--
  L3: 逻辑编排层 (Orchestration)
  创建时间: 2024
  用途: 详细定义第三层的架构、接口、耦合和测试规范
-->
<Layer id="L3" name="Orchestration" version="1.0">
  
  <!-- ==================== 1. 结构说明 ==================== -->
  <Structure>
    <Purpose>系统的指挥官，负责意图识别、任务拆解与思维链管理</Purpose>
    
    <Responsibilities>
      <Item priority="critical">意图识别（理解用户想要做什么）</Item>
      <Item priority="critical">任务规划（拆解复杂请求为可执行步骤）</Item>
      <Item priority="critical">ReAct循环驱动（Thought → Action → Observation）</Item>
      <Item priority="high">LLM调用管理（对话管理、Token优化）</Item>
      <Item priority="high">工具调用决策（决定何时调用工具、调用什么工具）</Item>
      <Item priority="medium">思维链展示（提供思考过程给用户）</Item>
      <Item priority="medium">错误恢复（LLM调用失败时的重试和降级）</Item>
    </Responsibilities>
    
    <Components>
      <Component name="ReActEngine">
        <Description>ReAct循环引擎，实现Thought-Action-Observation循环</Description>
        <Workflow>
          <Step name="Thought">分析当前状态，决定下一步行动</Step>
          <Step name="Action">执行决策（调用工具或直接回复）</Step>
          <Step name="Observation">观察执行结果，更新状态</Step>
          <LoopCondition>达到终止条件（得到答案或达到最大轮数）</LoopCondition>
        </Workflow>
        <MaxIterations>5</MaxIterations>
        <TerminationConditions>
          <Condition>得到最终答案</Condition>
          <Condition>达到最大迭代次数</Condition>
          <Condition>用户请求直接回复</Condition>
        </TerminationConditions>
      </Component>
      
      <Component name="IntentRecognizer">
        <Description>意图识别器，分析用户输入的意图</Description>
        <IntentTypes>
          <Type>chat - 闲聊对话</Type>
          <Type>query - 信息查询</Type>
          <Type>action - 需要执行操作</Type>
          <Type>code - 代码生成或执行</Type>
          <Type>clarification - 需要澄清</Type>
        </IntentTypes>
        <Method>recognize(query: str, history: List) -&gt; Intent</Method>
      </Component>
      
      <Component name="TaskPlanner">
        <Description>任务规划器，将复杂请求拆解为子任务</Description>
        <Method>plan(intent: Intent, context: SessionContext) -&gt; TaskGraph</Method>
        <TaskTypes>
          <Type>atomic - 原子任务，可直接执行</Type>
          <Type>composite - 复合任务，需要拆解</Type>
          <Type>conditional - 条件任务，根据结果分支</Type>
        </TaskTypes>
      </Component>
      
      <Component name="LLMManager">
        <Description>LLM调用管理器，封装大模型交互</Description>
        <Providers>
          <Provider>OpenAI GPT-4/GPT-3.5</Provider>
          <Provider>Anthropic Claude</Provider>
          <Provider>本地模型（Ollama）</Provider>
        </Providers>
        <Methods>
          <Method>complete(messages: List, tools: List) -&gt; LLMResponse</Method>
          <Method>stream(messages: List) -&gt; Iterator[str]</Method>
        </Methods>
        <Configuration>
          <MaxTokens>4096</MaxTokens>
          <Temperature>0.7</Temperature>
          <Timeout>30秒</Timeout>
        </Configuration>
      </Component>
      
      <Component name="ToolCaller">
        <Description>工具调用器，与L5交互执行工具</Description>
        <Interface>调用L5.execute(action_name, params)</Interface>
        <Methods>
          <Method>call_tool(action: AgentAction) -&gt; Observation</Method>
          <Method>format_tools_for_llm() -&gt; List[dict]</Method>
        </Methods>
      </Component>
      
      <Component name="MemoryAccessor">
        <Description>记忆访问器，从L4检索相关知识</Description>
        <Interface>调用L4.search(query, top_k)</Interface>
        <Methods>
          <Method>retrieve_relevant(query: str, top_k: int) -&gt; List[str]</Method>
          <Method>enhance_context(context: SessionContext) -&gt; EnhancedContext</Method>
        </Methods>
      </Component>
    </Components>
    
    <DataFlow>
      <Step order="1">接收SessionContext（来自L2）</Step>
      <Step order="2">IntentRecognizer分析用户意图</Step>
      <Step order="3">MemoryAccessor从L4检索相关知识</Step>
      <Step order="4">TaskPlanner根据意图规划任务</Step>
      <Step order="5">ReActEngine启动循环</Step>
      <Step order="6">LLMManager生成Thought（分析当前状态）</Step>
      <Step order="7">决策：调用工具或直接回复</Step>
      <Step order="8a" condition="调用工具">ToolCaller调用L5.execute()</Step>
      <Step order="9a">接收Observation（来自L5）</Step>
      <Step order="10a">回到Step 6（继续ReAct循环）</Step>
      <Step order="8b" condition="直接回复">生成最终回复</Step>
      <Step order="9b">返回回复文本给L2</Step>
    </DataFlow>
  </Structure>
  
  <!-- ==================== 2. 接口规范 ==================== -->
  <Interface>
    <PrimaryMethod name="run">
      <Signature>
        <Input>
          <Parameter name="context" type="SessionContext" required="true">
            <Description>来自L2的会话上下文</Description>
          </Parameter>
          <Parameter name="observation" type="Observation" required="false">
            <Description>执行观察结果（ReAct循环中来自L5的反馈）</Description>
          </Parameter>
        </Input>
        
        <Output>
          <Variant condition="最终回复" type="str">
            <Description>返回给用户的最终回复文本</Description>
            <Example>"根据计算，1+1=2"</Example>
          </Variant>
          
          <Variant condition="内部流转" type="AgentAction">
            <Description>发送给L5的工具调用指令</Description>
            <Fields>
              <Field name="action" type="str" required="true">
                <Description>工具名称</Description>
                <ValidValues>python_repl, search_web, file_read, file_write</ValidValues>
              </Field>
              <Field name="action_input" type="dict" required="true">
                <Description>工具参数</Description>
                <Example>{"code": "print('hello')"}</Example>
              </Field>
              <Field name="thought" type="str" required="false">
                <Description>LLM的思考过程</Description>
              </Field>
            </Fields>
          </Variant>
        </Output>
        
        <Exceptions>
          <Exception name="LLMError">
            <Description>大模型调用失败</Description>
            <ErrorCode>503</ErrorCode>
            <RetryPolicy>自动重试3次，指数退避</RetryPolicy>
          </Exception>
          <Exception name="MaxIterationsExceeded">
            <Description>达到最大ReAct迭代次数仍未得到答案</Description>
            <ErrorCode>422</ErrorCode>
          </Exception>
          <Exception name="ToolExecutionError">
            <Description>工具调用失败（由L5返回）</Description>
            <ErrorCode>500</ErrorCode>
          </Exception>
        </Exceptions>
      </Signature>
    </PrimaryMethod>
    
    <SecondaryMethod name="format_response">
      <Signature>
        <Input>
          <Parameter name="content" type="str" required="true">
            <Description>原始回复内容</Description>
          </Parameter>
          <Parameter name="include_thoughts" type="bool" required="false" default="false">
            <Description>是否包含思考过程</Description>
          </Parameter>
        </Input>
        
        <Output type="str">
          <Description>格式化后的回复</Description>
        </Output>
      </Signature>
    </SecondaryMethod>
  </Interface>
  
  <!-- ==================== 3. 耦合关系 ==================== -->
  <Coupling>
    <Upstream>
      <Layer id="L2">控制网关层 (Control Gateway)</Layer>
      <Relation>被调用（接收SessionContext）</Relation>
      <Method>L2调用L3.run(context: SessionContext)</Method>
      <DataFormat>SessionContext对象</DataFormat>
    </Upstream>
    
    <Downstream>
      <Layer id="L2">控制网关层 (Control Gateway)</Layer>
      <Relation>回调（返回最终回复）</Relation>
      <Method>返回str给L2.send_response()</Method>
      <DataFormat>字符串</DataFormat>
    </Downstream>
    
    <ExternalDependencies>
      <Dependency id="L4">
        <Layer>记忆与知识层 (Memory &amp; Knowledge)</Layer>
        <Interface>MemoryInterface</Interface>
        <Usage>MemoryAccessor调用L4.search()检索知识</Usage>
        <CouplingType>依赖注入（接口抽象）</CouplingType>
      </Dependency>
      
      <Dependency id="L5">
        <Layer>能力抽象层 (Tools &amp; Capabilities)</Layer>
        <Interface>ToolsInterface</Interface>
        <Usage>ToolCaller调用L5.execute()执行工具</Usage>
        <CouplingType>依赖注入（接口抽象）</CouplingType>
      </Dependency>
      
      <Dependency id="External">
        <Layer>外部LLM服务</Layer>
        <Usage>LLMManager调用OpenAI/Claude API</Usage>
        <CouplingType>外部服务调用</CouplingType>
      </Dependency>
    </ExternalDependencies>
    
    <Dependencies>
      <Internal>
        <Dependency>models.SessionContext - 输入数据结构</Dependency>
        <Dependency>models.AgentAction - 工具调用指令</Dependency>
        <Dependency>models.Observation - 工具执行结果</Dependency>
        <Dependency>interfaces.MemoryInterface - L4接口</Dependency>
        <Dependency>interfaces.ToolsInterface - L5接口</Dependency>
      </Internal>
      <External>
        <Dependency>openai - OpenAI API客户端</Dependency>
        <Dependency>anthropic - Anthropic API客户端</Dependency>
      </External>
    </Dependencies>
    
    <CouplingStrength>中等耦合</CouplingStrength>
    <CouplingType>依赖注入（通过接口与L4、L5通信）</CouplingType>
    
    <Note>
      L3是系统的智能核心，通过依赖注入解耦与L4、L5的关系。L3不直接实例化L4/L5，
      而是通过构造函数接收接口实现。这使得L3可以独立测试，也便于替换底层实现。
    </Note>
  </Coupling>
  
  <!-- ==================== 4. Mock测试规范 ==================== -->
  <Testing>
    <Strategy>Mock L4、L5和LLM服务，验证编排逻辑和ReAct循环</Strategy>
    
    <TestCases>
      <TestCase id="TC-L3-001" priority="critical">
        <Name>简单对话回复（无需工具）</Name>
        <Objective>验证简单闲聊能直接生成回复，不调用工具</Objective>
        <MockObjects>
          <Mock>IntentRecognizer - 返回chat意图</Mock>
          <Mock>LLMManager - 返回模拟回复</Mock>
        </MockObjects>
        <Steps>
          <Step>构造SessionContext，内容为"你好"</Step>
          <Step>调用run(context)</Step>
        </Steps>
        <Expected>
          <Check>返回字符串类型的回复</Check>
          <Check>未调用L5.execute()</Check>
          <Check>ReAct循环迭代1次后终止</Check>
        </Expected>
      </TestCase>
      
      <TestCase id="TC-L3-002" priority="critical">
        <Name>单步工具调用</Name>
        <Objective>验证需要工具时能正确调用并返回结果</Objective>
        <MockObjects>
          <Mock>IntentRecognizer - 返回code意图</Mock>
          <Mock>LLMManager - 第一次返回AgentAction，第二次返回最终回复</Mock>
          <Mock>L5.execute() - 返回成功的Observation</Mock>
        </MockObjects>
        <Steps>
          <Step>构造SessionContext，内容为"计算1+1"</Step>
          <Step>第一次调用run(context)</Step>
          <Step>验证返回AgentAction</Step>
          <Step>构造Observation（模拟L5返回结果）</Step>
          <Step>第二次调用run(context, observation)</Step>
        </Steps>
        <Expected>
          <Check>第一次返回AgentAction，action="python_repl"</Check>
          <Check>action_input包含代码"1+1"</Check>
          <Check>第二次返回最终回复字符串</Check>
          <Check>ReAct循环迭代2次后终止</Check>
        </Expected>
      </TestCase>
      
      <TestCase id="TC-L3-003" priority="critical">
        <Name>多步ReAct循环</Name>
        <Objective>验证复杂任务需要多步工具调用时能正确处理</Objective>
        <MockObjects>
          <Mock>LLMManager - 模拟多轮Thought-Action</Mock>
          <Mock>L5.execute() - 返回多轮Observation</Mock>
        </MockObjects>
        <Steps>
          <Step>构造需要3步工具的复杂查询</Step>
          <Step>循环调用run() 3次，每次传入前一次的Observation</Step>
        </Steps>
        <Expected>
          <Check>前2次返回AgentAction</Check>
          <Check>第3次返回最终回复</Check>
          <Check>每次调用不同的工具</Check>
        </Expected>
      </TestCase>
      
      <TestCase id="TC-L3-004" priority="high">
        <Name>LLM调用失败重试</Name>
        <Objective>验证LLM调用失败时会自动重试</Objective>
        <MockObjects>
          <Mock>LLMManager - 前2次失败，第3次成功</Mock>
        </MockObjects>
        <Steps>
          <Step>构造SessionContext</Step>
          <Step>调用run(context)</Step>
        </Steps>
        <Expected>
          <Check>LLMManager被调用3次</Check>
          <Check>最终返回成功回复</Check>
          <Check>每次重试间隔递增（指数退避）</Check>
        </Expected>
      </TestCase>
      
      <TestCase id="TC-L3-005" priority="high">
        <Name>意图识别准确性</Name>
        <Objective>验证意图识别器能正确分类用户请求</Objective>
        <MockObjects>无</MockObjects>
        <Steps>
          <Step>测试各类查询："你好", "查天气", "写代码", "帮我算一下"</Step>
          <Step>调用IntentRecognizer.recognize()</Step>
        </Steps>
        <Expected>
          <Check>"你好" -&gt; chat</Check>
          <Check>"查天气" -&gt; query</Check>
          <Check>"写代码" -&gt; code</Check>
          <Check>"帮我算一下" -&gt; action</Check>
        </Expected>
      </TestCase>
      
      <TestCase id="TC-L3-006" priority="medium">
        <Name>L4知识检索增强</Name>
        <Objective>验证能从L4检索知识并注入上下文</Objective>
        <MockObjects>
          <Mock>L4.search() - 返回相关知识片段</Mock>
        </MockObjects>
        <Steps>
          <Step>构造关于特定知识的查询</Step>
          <Step>调用run(context)</Step>
        </Steps>
        <Expected>
          <Check>L4.search()被调用，传入当前查询</Check>
          <Check>检索结果被注入LLM的上下文</Check>
        </Expected>
      </TestCase>
      
      <TestCase id="TC-L3-007" priority="medium">
        <Name>最大迭代次数限制</Name>
        <Objective>验证超过最大迭代次数会抛出异常</Objective>
        <MockObjects>
          <Mock>LLMManager - 始终返回AgentAction（永不结束）</Mock>
        </MockObjects>
        <Steps>
          <Step>构造SessionContext</Step>
          <Step>循环调用run() 6次（超过MaxIterations=5）</Step>
        </Steps>
        <Expected>
          <Check>第6次调用抛出MaxIterationsExceeded</Check>
          <Check>错误信息提示用户任务过于复杂</Check>
        </Expected>
      </TestCase>
    </TestCases>
    
    <TDDApproach>
      <Phase name="Red">
        <Action>为ReAct循环、意图识别、LLM管理编写失败测试</Action>
        <Verify>测试失败，确认功能缺失</Verify>
      </Phase>
      <Phase name="Green">
        <Action>实现最简单的ReAct引擎和工具调用逻辑</Action>
        <Verify>所有测试通过，包括单步和多步场景</Verify>
      </Phase>
      <Phase name="Refactor">
        <Action>优化循环逻辑，添加错误处理和重试机制</Action>
        <Verify>测试持续通过，代码结构清晰</Verify>
      </Phase>
    </TDDApproach>
  </Testing>
  
</Layer>
