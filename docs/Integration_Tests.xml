<!--
  Integration Tests Specification
  集成测试规范文档
  创建时间: 2024
  用途: 详细定义端到端集成测试的规范、场景和验证标准
-->
<IntegrationTests id="E2E" name="End-to-End Integration Tests" version="1.0">
  
  <!-- ==================== 1. 概述 ==================== -->
  <Overview>
    <Purpose>验证六层架构的完整协作能力和端到端工作流程</Purpose>
    <Coverage>跨层集成测试，覆盖所有六层的协作场景</Coverage>
    <TotalTests>23</TotalTests>
  <Optimization>
    <OriginalCount>28</OriginalCount>
    <RemovedTests>5</RemovedTests>
    <CurrentCount>23</CurrentCount>
    <Reason>删除与单元测试完全重复的测试用例，降低维护成本</Reason>
    <RemovedTestIds>ERROR-002, ERROR-004, SECURITY-002, SECURITY-004, RESOURCE-003</RemovedTestIds>
  </Optimization>
    <TestFile>tests/test_integration.py</TestFile>
    <LinesOfCode>879</LinesOfCode>
  </Overview>
  
  <!-- ==================== 2. 测试分类 ==================== -->
  <TestCategories>
    
    <Category id="E2E" name="End-to-End Workflows" testCount="4">
      <Description>完整的端到端工作流测试</Description>
      <Coverage>覆盖从L1到L6的完整数据流</Coverage>
      
      <TestCase id="E2E-001">
        <Name>Simple Chat Flow</Name>
        <NameCN>简单聊天流程</NameCN>
        <Objective>验证无需工具执行的简单对话流程</Objective>
        <Flow>
          <Step layer="L1">接收Telegram/WebSocket消息 → 生成StandardEvent</Step>
          <Step layer="L2">鉴权/限流 → 组装SessionContext</Step>
          <Step layer="L3">意图识别 → 生成回复</Step>
          <Step layer="L2">发送响应</Step>
        </Flow>
        <Expected>
          <Check>数据在各层正确传递</Check>
          <Check>最终响应符合预期</Check>
          <Check>无工具调用发生</Check>
        </Expected>
      </TestCase>
      
      <TestCase id="E2E-002">
        <Name>Calculator Tool Flow</Name>
        <NameCN>计算器工具执行流程</NameCN>
        <Objective>验证计算器工具的端到端执行</Objective>
        <Flow>
          <Step layer="L1-L2">用户请求 → SessionContext</Step>
          <Step layer="L3">识别为action意图</Step>
          <Step layer="L5">执行calculator工具（无需L6）</Step>
          <Step layer="L5">返回Observation</Step>
        </Flow>
        <Expected>
          <Check>计算结果正确 (123 * 456 = 56088)</Check>
          <Check>权限检查通过（calculator无需特殊权限）</Check>
        </Expected>
      </TestCase>
      
      <TestCase id="E2E-003">
        <Name>Code Execution Flow</Name>
        <NameCN>代码执行完整流程</NameCN>
        <Objective>验证通过L6执行Python代码的完整流程</Objective>
        <Flow>
          <Step layer="L1-L2">用户代码执行请求</Step>
          <Step layer="L3">识别为code/action意图</Step>
          <Step layer="L5">权限检查（需要execute_code权限）</Step>
          <Step layer="L5-L6">路由到RuntimeEnvironment</Step>
          <Step layer="L6">沙盒创建 → 代码执行 → 沙盒销毁</Step>
          <Step layer="L6-L5">返回ExecutionResult</Step>
          <Step layer="L5-L3">格式化为Observation</Step>
        </Flow>
        <Expected>
          <Check>沙盒正确创建和销毁</Check>
          <Check>代码执行结果正确返回</Check>
          <Check>资源使用统计完整</Check>
        </Expected>
      </TestCase>
      
      <TestCase id="E2E-004">
        <Name>Memory Retrieval Flow</Name>
        <NameCN>知识检索流程</NameCN>
        <Objective>验证L3通过L4检索知识的流程</Objective>
        <Flow>
          <Step layer="L4">预存储知识文档</Step>
          <Step layer="L1-L2">用户查询请求</Step>
          <Step layer="L3-L4">调用search()检索相关知识</Step>
          <Step layer="L4">向量相似度搜索</Step>
          <Step layer="L4-L3">返回相关记忆片段</Step>
          <Step layer="L3">基于知识生成回复</Step>
        </Flow>
        <Expected>
          <Check>检索到相关文档</Check>
          <Check>知识片段用于回复生成</Check>
          <Check>缓存机制正常工作</Check>
        </Expected>
      </TestCase>
    </Category>
    
    <Category id="REACT" name="ReAct Loop Tests" testCount="2">
      <Description>ReAct (Reasoning + Acting) 循环测试</Description>
      <Coverage>L3的推理和行动循环机制</Coverage>
      
      <TestCase id="REACT-001">
        <Name>Single Tool ReAct Iteration</Name>
        <NameCN>单轮工具调用ReAct迭代</NameCN>
        <Objective>验证单轮工具调用的ReAct循环</Objective>
        <Flow>
          <Step>L3识别需要工具调用</Step>
          <Step>生成AgentAction（calculator，无需高权限）</Step>
          <Step>L5执行工具</Step>
          <Step>返回Observation给L3</Step>
          <Step>L3生成最终回复</Step>
        </Flow>
        <Expected>
          <Check>计算结果正确（15 * 23 = 345）</Check>
          <Check>迭代计数正确</Check>
          <Check>最终回复为字符串类型</Check>
        </Expected>
      </TestCase>
      
      <TestCase id="REACT-002">
        <Name>Max Iterations Protection</Name>
        <NameCN>最大迭代保护</NameCN>
        <Objective>防止无限ReAct循环</Objective>
        <Scenario>Mock LLM总是返回工具调用</Scenario>
        <Expected>
          <Check>达到MAX_ITERATIONS(5)后停止</Check>
          <Check>抛出MaxIterationsExceeded异常</Check>
          <Check>系统不进入死循环</Check>
        </Expected>
      </TestCase>
    </Category>
    
    <Category id="ERROR" name="Error Propagation" testCount="3">
      <Description>错误传播和处理测试</Description>
      <Coverage>跨层错误传播和恢复机制</Coverage>
      
      <TestCase id="ERROR-001">
        <Name>L6 Error Propagates to L5</Name>
        <NameCN>L6错误传播到L5</NameCN>
        <Objective>验证L6执行错误被L5捕获并格式化</Objective>
        <Scenario>执行1/0触发ZeroDivisionError</Scenario>
        <Expected>
          <Check>Observation.status == "error"</Check>
          <Check>错误信息包含ZeroDivisionError</Check>
          <Check>不抛出异常，正常返回Observation</Check>
        </Expected>
      </TestCase>
      
      
      <TestCase id="ERROR-002">
        <Name>L2 Rate Limit Error</Name>
        <NameCN>L2限流错误</NameCN>
        <Objective>验证速率限制生效</Objective>
        <Scenario>同一用户70次请求/分钟（限制60次）</Scenario>
        <Expected>
          <Check>前60次请求成功</Check>
          <Check>第61次起抛出RateLimitExceeded</Check>
          <Check>限流窗口正确滑动</Check>
        </Expected>
      </TestCase>
      
      
      <TestCase id="ERROR-003">
        <Name>Error Recovery</Name>
        <NameCN>错误恢复和继续</NameCN>
        <Objective>验证系统能从错误中恢复</Objective>
        <Scenario>错误请求 → 有效请求</Scenario>
        <Expected>
          <Check>错误请求被拒绝</Check>
          <Check>后续有效请求正常处理</Check>
          <Check>系统状态保持一致</Check>
        </Expected>
      </TestCase>
    </Category>
    
    <Category id="COLLAB" name="Multi-Layer Collaboration" testCount="3">
      <Description>多层协作测试</Description>
      <Coverage>多个层次同时参与的复杂场景</Coverage>
      
      <TestCase id="COLLAB-001">
        <Name>L3 Uses Both L4 and L5</Name>
        <NameCN>L3同时使用L4和L5</NameCN>
        <Objective>验证L3能协调记忆和工具</Objective>
        <Flow>
          <Step>L3从L4检索知识</Step>
          <Step>L3使用L5获取可用工具</Step>
          <Step>L3综合信息生成回复</Step>
        </Flow>
        <Expected>
          <Check>L4.search()被调用</Check>
          <Check>L5.get_available_tools()被调用</Check>
          <Check>两者结果都被使用</Check>
        </Expected>
      </TestCase>
      
      <TestCase id="COLLAB-002">
        <Name>Session History Integration</Name>
        <NameCN>会话历史集成</NameCN>
        <Objective>验证跨多轮的对话历史维护</Objective>
        <Flow>
          <Step>Turn 1: 用户发送消息，系统回复</Step>
          <Step>存储对话历史到L4</Step>
          <Step>Turn 2: 用户发送后续消息</Step>
          <Step>L2检索历史上下文</Step>
        </Flow>
        <Expected>
          <Check>历史记录完整保存</Check>
          <Check>后续请求能获取历史</Check>
          <Check>历史格式符合OpenAI消息格式</Check>
        </Expected>
      </TestCase>
      
      <TestCase id="COLLAB-003">
        <Name>L5 Tool Routing to L6</Name>
        <NameCN>L5工具路由到L6</NameCN>
        <Objective>验证L5正确委托代码执行给L6</Objective>
        <Flow>
          <Step>L5接收python_repl工具调用</Step>
          <Step>验证权限和参数</Step>
          <Step>调用L6.run_code()</Step>
          <Step>格式化L6返回结果</Step>
        </Flow>
        <Expected>
          <Check>L6被正确调用</Check>
          <Check>执行结果被正确格式化</Check>
          <Check>执行时间被记录</Check>
        </Expected>
      </TestCase>
    </Category>
    
    <Category id="SECURITY" name="Security and Boundaries" testCount="2">
      <Description>安全和边界测试</Description>
      <Coverage>安全控制和边界保护</Coverage>
      
      <TestCase id="SECURITY-001">
        <Name>L6 Security Blocks Dangerous Code</Name>
        <NameCN>L6阻止危险代码</NameCN>
        <Objective>验证安全策略执行</Objective>
        <TestCases>
          <Case code="import os; os.system('rm -rf /')">禁止os.system</Case>
          <Case code="eval('1+1')">禁止eval</Case>
          <Case code="exec('print(1)')">禁止exec</Case>
        </TestCases>
        <Expected>
          <Check>抛出SecurityViolationError</Check>
          <Check>代码不被执行</Check>
        </Expected>
      </TestCase>
      
      
      <TestCase id="SECURITY-002">
        <Name>L2 Authentication Check</Name>
        <NameCN>L2身份验证检查</NameCN>
        <Objective>验证令牌验证</Objective>
        <Scenario>使用invalid_token</Scenario>
        <Expected>
          <Check>抛出AuthenticationError</Check>
        </Expected>
      </TestCase>
      
      
    </Category>
    
    <Category id="RESOURCE" name="Resource Limits" testCount="2">
      <Description>资源限制测试</Description>
      <Coverage>超时、内存、输出限制</Coverage>
      
      <TestCase id="RESOURCE-001">
        <Name>L6 Timeout Enforcement</Name>
        <NameCN>L6超时强制执行</NameCN>
        <Objective>验证超时机制</Objective>
        <Scenario>执行time.sleep(10)，设置timeout=1</Scenario>
        <Expected>
          <Check>抛出ExecutionTimeoutError</Check>
          <Check>执行时间约1秒</Check>
          <Check>子进程被正确终止</Check>
        </Expected>
      </TestCase>
      
      <TestCase id="RESOURCE-002">
        <Name>L6 Output Truncation</Name>
        <NameCN>L6输出截断</NameCN>
        <Objective>验证大输出被截断</Objective>
        <Scenario>生成20KB输出</Scenario>
        <Expected>
          <Check>输出长度 ≤ 10000字符</Check>
        </Expected>
      </TestCase>
      
      
    </Category>
    
    <Category id="COMPLEX" name="Complex Scenarios" testCount="4">
      <Description>复杂场景测试</Description>
      <Coverage>真实世界复杂场景模拟</Coverage>
      
      <TestCase id="COMPLEX-001">
        <Name>Full Agent Workflow</Name>
        <NameCN>完整Agent工作流</NameCN>
        <Objective>模拟真实用户交互</Objective>
        <Scenario>用户查询技术信息，系统检索知识并回复</Scenario>
        <Expected>
          <Check>知识检索成功</Check>
          <Check>回复生成完成</Check>
          <Check>全流程无错误</Check>
        </Expected>
      </TestCase>
      
      <TestCase id="COMPLEX-002">
        <Name>Multi-Turn Conversation</Name>
        <NameCN>多轮对话</NameCN>
        <Objective>验证上下文在多轮中保持</Objective>
        <Scenario>3轮对话，每轮引用前文</Scenario>
        <Expected>
          <Check>每轮都能获取完整历史</Check>
          <Check>会话隔离正确</Check>
        </Expected>
      </TestCase>
      
      <TestCase id="COMPLEX-003">
        <Name>Error Recovery and Continuation</Name>
        <NameCN>错误恢复和继续</NameCN>
        <Objective>验证系统鲁棒性</Objective>
        <Scenario>错误请求 → 运行时错误 → 有效请求</Scenario>
        <Expected>
          <Check>系统不因错误崩溃</Check>
          <Check>有效请求正常处理</Check>
        </Expected>
      </TestCase>
      
      <TestCase id="COMPLEX-004">
        <Name>Concurrent Session Isolation</Name>
        <NameCN>并发会话隔离</NameCN>
        <Objective>验证多用户会话隔离</Objective>
        <Scenario>用户A和用户B同时会话</Scenario>
        <Expected>
          <Check>会话ID不同</Check>
          <Check>历史记录不混淆</Check>
          <Check>数据完全隔离</Check>
        </Expected>
      </TestCase>
    </Category>
    
    <Category id="MOCK" name="Layer Independence" testCount="2">
      <Description>层独立性测试</Description>
      <Coverage>验证各层可通过Mock独立测试</Coverage>
      
      <TestCase id="MOCK-001">
        <Name>L3 with Mocked L4 and L5</Name>
        <NameCN>Mock依赖的L3测试</NameCN>
        <Objective>演示L3可独立测试</Objective>
        <Expected>
          <Check>Mock对象被正确调用</Check>
          <Check>L3逻辑正确执行</Check>
        </Expected>
      </TestCase>
      
      <TestCase id="MOCK-002">
        <Name>L2 with Mocked L4</Name>
        <NameCN>Mock依赖的L2测试</NameCN>
        <Objective>演示L2可独立测试</Objective>
        <Expected>
          <Check>Mock L4被正确调用</Check>
          <Check>历史记录从Mock获取</Check>
        </Expected>
      </TestCase>
    </Category>
    
    <Category id="ARCH" name="Architecture Verification" testCount="1">
      <Description>架构验证测试</Description>
      <Coverage>验证架构依赖方向</Coverage>
      
      <TestCase id="ARCH-001">
        <Name>Architecture Dependencies</Name>
        <NameCN>架构依赖验证</NameCN>
        <Objective>验证依赖方向符合设计</Objective>
        <Expected>
          <Check>L1只依赖models</Check>
          <Check>L2依赖L4</Check>
          <Check>L3依赖L4和L5</Check>
          <Check>L5依赖L6</Check>
          <Check>L6无下层依赖</Check>
        </Expected>
      </TestCase>
    </Category>
  </TestCategories>
  
  <!-- ==================== 3. 测试数据流 ==================== -->
  <DataFlow>
    <Path id="simple-chat">
      <Name>Simple Chat Flow</Name>
      <Steps>
        <Step from="External" to="L1" data="raw_payload">用户输入</Step>
        <Step from="L1" to="L2" data="StandardEvent">标准化事件</Step>
        <Step from="L2" to="L3" data="SessionContext">会话上下文</Step>
        <Step from="L2" to="L4" data="session_id">历史检索</Step>
        <Step from="L4" to="L2" data="history">历史记录</Step>
        <Step from="L3" to="L2" data="str">回复文本</Step>
        <Step from="L2" to="External" data="response">发送给用户</Step>
      </Steps>
    </Path>
    
    <Path id="tool-execution">
      <Name>Tool Execution Flow</Name>
      <Steps>
        <Step from="External" to="L1" data="raw_payload">用户输入</Step>
        <Step from="L1" to="L2" data="StandardEvent">标准化事件</Step>
        <Step from="L2" to="L3" data="SessionContext">会话上下文</Step>
        <Step from="L3" to="L5" data="AgentAction">工具调用指令</Step>
        <Step from="L5" to="L6" data="code">执行代码</Step>
        <Step from="L6" to="L5" data="ExecutionResult">执行结果</Step>
        <Step from="L5" to="L3" data="Observation">观察结果</Step>
        <Step from="L3" to="L2" data="str">最终回复</Step>
      </Steps>
    </Path>
    
    <Path id="knowledge-retrieval">
      <Name>Knowledge Retrieval Flow</Name>
      <Steps>
        <Step from="External" to="L1" data="raw_payload">用户查询</Step>
        <Step from="L2" to="L3" data="SessionContext">会话上下文</Step>
        <Step from="L3" to="L4" data="query">检索查询</Step>
        <Step from="L4" to="L3" data="knowledge">相关知识</Step>
        <Step from="L3" to="L2" data="str">增强回复</Step>
      </Steps>
    </Path>
  </DataFlow>
  
  <!-- ==================== 4. 测试环境配置 ==================== -->
  <Environment>
    <Requirements>
      <PythonVersion>3.11+</PythonVersion>
      <TestFramework>pytest</TestFramework>
      <CoverageTool>pytest-cov</CoverageTool>
    </Requirements>
    
    <Fixtures>
      <Fixture name="sample_event">
        <Description>示例StandardEvent</Description>
        <Usage>用于需要事件的测试</Usage>
      </Fixture>
      <Fixture name="sample_context">
        <Description>示例SessionContext</Description>
        <Usage>用于需要上下文的测试</Usage>
      </Fixture>
    </Fixtures>
    
    <Configuration>
      <Item>测试在隔离环境中运行</Item>
      <Item>每个测试独立，无共享状态</Item>
      <Item>使用Mock隔离外部依赖</Item>
      <Item>真实L6沙盒在临时目录中创建</Item>
    </Configuration>
  </Environment>
  
  <!-- ==================== 5. 成功标准 ==================== -->
  <SuccessCriteria>
    <AllTestsPass>28/28 测试通过</AllTestsPass>
    <Coverage>所有六层都有集成测试覆盖</Coverage>
    <ErrorHandling>所有异常路径都被测试</ErrorHandling>
    <Security>所有安全控制都被验证</Security>
    <Performance>超时和资源限制测试通过</Performance>
  </SuccessCriteria>
  
  <!-- ==================== 6. 运行命令 ==================== -->
  <Commands>
    <Command id="all">
      <Line>pytest tests/ -v</Line>
      <Description>运行所有测试（单元+集成）</Description>
    </Command>
    <Command id="integration">
      <Line>pytest tests/test_integration.py -v</Line>
      <Description>仅运行集成测试</Description>
    </Command>
    <Command id="category">
      <Line>pytest tests/test_integration.py::TestEndToEndWorkflows -v</Line>
      <Description>运行特定分类测试</Description>
    </Command>
    <Command id="specific">
      <Line>pytest tests/test_integration.py::TestEndToEndWorkflows::test_simple_chat_flow -v</Line>
      <Description>运行特定测试</Description>
    </Command>
    <Command id="cov">
      <Line>pytest tests/ --cov=src --cov-report=html</Line>
      <Description>生成覆盖率报告</Description>
    </Command>
  </Commands>
  
</IntegrationTests>
