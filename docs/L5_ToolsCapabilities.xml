<?xml version="1.0" encoding="UTF-8"?>
<!--
  L5: 能力抽象层 (Tools &amp; Capabilities)
  创建时间: 2024
  用途: 详细定义第五层的架构、接口、耦合和测试规范
-->
<Layer id="L5" name="ToolsCapabilities" version="1.0">
  
  <!-- ==================== 1. 结构说明 ==================== -->
  <Structure>
    <Purpose>系统的技能包，负责工具定义、API封装与函数调用协议</Purpose>
    
    <Responsibilities>
      <Item priority="critical">工具注册与发现（动态加载和管理工具）</Item>
      <Item priority="critical">参数验证（JSON Schema校验LLM生成的参数）</Item>
      <Item priority="critical">权限检查（验证用户是否有权限调用特定工具）</Item>
      <Item priority="high">工具路由（将工具名映射到实际执行器）</Item>
      <Item priority="high">结果格式化（统一工具执行结果的输出格式）</Item>
      <Item priority="medium">工具元数据管理（描述工具功能供LLM使用）</Item>
      <Item priority="medium">执行超时控制（防止工具执行时间过长）</Item>
    </Responsibilities>
    
    <Components>
      <Component name="ToolRegistry">
        <Description>工具注册表，管理所有可用工具</Description>
        <Methods>
          <Method>register(name: str, tool: Tool) -&gt; None</Method>
          <Method>unregister(name: str) -&gt; None</Method>
          <Method>get(name: str) -&gt; Optional[Tool]</Method>
          <Method>list_tools() -&gt; List[Tool]</Method>
        </Methods>
        <SupportedTools>
          <Tool name="python_repl">
            <Description>执行Python代码</Description>
            <Params>{"code": "要执行的代码"}</Params>
            <RequiresPermission>execute_code</RequiresPermission>
          </Tool>
          <Tool name="search_web">
            <Description>搜索网络</Description>
            <Params>{"query": "搜索关键词"}</Params>
            <RequiresPermission>web_access</RequiresPermission>
          </Tool>
          <Tool name="file_read">
            <Description>读取文件</Description>
            <Params>{"path": "文件路径"}</Params>
            <RequiresPermission>file_read</RequiresPermission>
          </Tool>
          <Tool name="file_write">
            <Description>写入文件</Description>
            <Params>{"path": "文件路径", "content": "内容"}</Params>
            <RequiresPermission>file_write</RequiresPermission>
          </Tool>
          <Tool name="terminal">
            <Description>执行终端命令</Description>
            <Params>{"command": "命令"}</Params>
            <RequiresPermission>execute_command</RequiresPermission>
          </Tool>
          <Tool name="calculator">
            <Description>数学计算</Description>
            <Params>{"expression": "数学表达式"}</Params>
            <RequiresPermission>none</RequiresPermission>
          </Tool>
        </SupportedTools>
      </Component>
      
      <Component name="ParameterValidator">
        <Description>参数验证器，校验LLM生成的参数</Description>
        <Schema>JSON Schema</Schema>
        <Methods>
          <Method>validate(params: dict, schema: dict) -&gt; ValidationResult</Method>
          <Method>sanitize(params: dict, schema: dict) -&gt; dict</Method>
        </Methods>
        <ValidationRules>
          <Rule>参数类型匹配</Rule>
          <Rule>必需字段检查</Rule>
          <Rule>值范围限制</Rule>
          <Rule>字符串长度限制</Rule>
          <Rule>路径安全校验（防止目录遍历）</Rule>
        </ValidationRules>
      </Component>
      
      <Component name="PermissionChecker">
        <Description>权限检查器，验证用户工具调用权限</Description>
        <PermissionLevels>
          <Level>admin - 所有工具</Level>
          <Level>user - 安全工具（calculator, file_read）</Level>
          <Level>guest - 只读工具</Level>
        </PermissionLevels>
        <Methods>
          <Method>check(user_permissions: List[str], tool_name: str) -&gt; bool</Method>
        </Methods>
      </Component>
      
      <Component name="ToolExecutor">
        <Description>工具执行器，实际调用工具实现</Description>
        <Methods>
          <Method>execute(tool: Tool, params: dict) -&gt; ExecutionResult</Method>
        </Methods>
        <Timeout>
          <Default>30秒</Default>
          <Max>300秒（5分钟）</Max>
        </Timeout>
      </Component>
      
      <Component name="ResultFormatter">
        <Description>结果格式化器，统一输出格式</Description>
        <Format>
          <Status>success / error</Status>
          <Result>结果字符串（截断至最大长度）</Result>
          <Metadata>执行时间、工具名等</Metadata>
        </Format>
        <MaxResultLength>10000字符</MaxResultLength>
      </Component>
      
      <Component name="ToolMetadataManager">
        <Description>工具元数据管理器，为LLM提供工具描述</Description>
        <Methods>
          <Method>get_tools_for_llm() -&gt; List[dict]</Method>
          <Method>get_tool_description(name: str) -&gt; dict</Method>
        </Methods>
        <Format>OpenAI Function Calling格式</Format>
      </Component>
    </Components>
    
    <DataFlow>
      <Step order="1">接收AgentAction（来自L3）</Step>
      <Step order="2">ToolRegistry查找工具</Step>
      <Step order="3">ParameterValidator验证参数</Step>
      <Step order="4">PermissionChecker检查权限</Step>
      <Step order="5">ToolExecutor执行工具（调用L6）</Step>
      <Step order="6">ResultFormatter格式化结果</Step>
      <Step order="7">返回Observation（给L3）</Step>
    </DataFlow>
  </Structure>
  
  <!-- ==================== 2. 接口规范 ==================== -->
  <Interface>
    <PrimaryMethod name="execute">
      <Signature>
        <Input>
          <Parameter name="action_name" type="str" required="true">
            <Description>工具名称</Description>
            <ValidValues>python_repl, search_web, file_read, file_write, terminal, calculator, ...</ValidValues>
          </Parameter>
          <Parameter name="params" type="dict" required="true">
            <Description>工具参数</Description>
            <Example>
              <![CDATA[
              {
                "code": "print('Hello World')",
                "language": "python"
              }
              ]]>
            </Example>
          </Parameter>
          <Parameter name="user_permissions" type="list[str]" required="true">
            <Description>调用者权限列表（来自SessionContext）</Description>
          </Parameter>
          <Parameter name="timeout" type="int" required="false" default="30">
            <Description>执行超时时间（秒）</Description>
            <Constraints>1 &lt;= timeout &lt;= 300</Constraints>
          </Parameter>
        </Input>
        
        <Output type="Observation">
          <Field name="status" type="str" required="true">
            <Description>执行状态</Description>
            <ValidValues>success, error</ValidValues>
          </Field>
          <Field name="result" type="str" required="true">
            <Description>执行结果的字符串表示</Description>
            <Constraints>最大长度10000字符，超出部分截断</Constraints>
          </Field>
          <Field name="execution_time" type="float" required="true">
            <Description>实际执行耗时（秒）</Description>
          </Field>
          <Field name="metadata" type="dict" required="false">
            <Description>附加元数据</Description>
            <Fields>
              <Field name="tool_name">工具名称</Field>
              <Field name="params" type="dict">实际使用的参数</Field>
              <Field name="exit_code" type="int">退出码（代码执行工具）</Field>
              <Field name="truncated" type="bool">结果是否被截断</Field>
            </Fields>
          </Field>
        </Output>
        
        <Exceptions>
          <Exception name="ToolNotFoundError">
            <Description>工具不存在</Description>
            <ErrorCode>404</ErrorCode>
          </Exception>
          <Exception name="ValidationError">
            <Description>参数验证失败</Description>
            <ErrorCode>400</ErrorCode>
          </Exception>
          <Exception name="PermissionDeniedError">
            <Description>用户无权调用此工具</Description>
            <ErrorCode>403</ErrorCode>
          </Exception>
          <Exception name="ExecutionTimeoutError">
            <Description>工具执行超时</Description>
            <ErrorCode>408</ErrorCode>
          </Exception>
          <Exception name="ExecutionError">
            <Description>工具执行失败（如代码运行时错误）</Description>
            <ErrorCode>500</ErrorCode>
          </Exception>
        </Exceptions>
      </Signature>
    </PrimaryMethod>
    
    <SecondaryMethod name="get_available_tools">
      <Signature>
        <Input>
          <Parameter name="user_permissions" type="list[str]" required="true">
            <Description>用户权限列表</Description>
          </Parameter>
        </Input>
        
        <Output type="list[dict]">
          <Description>用户可用的工具列表（OpenAI格式）</Description>
        </Output>
      </Signature>
    </SecondaryMethod>
  </Interface>
  
  <!-- ==================== 3. 耦合关系 ==================== -->
  <Coupling>
    <Upstream>
      <Layer id="L3">逻辑编排层 (Orchestration)</Layer>
      <Relation>被调用（接收AgentAction）</Relation>
      <Method>L3通过ToolsInterface调用L5.execute()</Method>
      <DataFormat>AgentAction对象</DataFormat>
    </Upstream>
    
    <Downstream>
      <Layer id="L6">环境执行层 (Runtime &amp; Environment)</Layer>
      <Relation>调用（执行实际代码）</Relation>
      <Method>L5调用L6.run_code()执行代码和命令</Method>
      <DataFormat>ExecutionResult对象</DataFormat>
      <Communication>进程间通信或方法调用</Communication>
    </Downstream>
    
    <Dependencies>
      <Internal>
        <Dependency>models.AgentAction - 输入数据结构</Dependency>
        <Dependency>models.Observation - 输出数据结构</Dependency>
        <Dependency>models.ExecutionResult - L6返回结果</Dependency>
        <Dependency>interfaces.ToolsInterface - 接口定义</Dependency>
        <Dependency>interfaces.RuntimeInterface - L6接口</Dependency>
      </Internal>
      <External>
        <Dependency>jsonschema - JSON Schema验证</Dependency>
        <Dependency>aiohttp - 网络请求（search_web工具）</Dependency>
        <Dependency>duckduckgo-search - 搜索API</Dependency>
      </External>
    </Dependencies>
    
    <CouplingStrength>中等耦合</CouplingStrength>
    <CouplingType>依赖注入（L5调用L6）+ 接口抽象（被L3调用）</CouplingType>
    
    <Note>
      L5是工具调用的中央路由，负责安全控制（权限、验证）。它通过接口调用L6执行实际代码，
      同时被L3通过接口调用。L5是安全边界，所有危险操作必须经过它的检查。
    </Note>
  </Coupling>
  
  <!-- ==================== 4. Mock测试规范 ==================== -->
  <Testing>
    <Strategy>Mock L6和权限系统，验证工具路由、验证、格式化逻辑</Strategy>
    
    <TestCases>
      <TestCase id="TC-L5-001" priority="critical">
        <Name>工具执行成功</Name>
        <Objective>验证正常参数能成功执行工具</Objective>
        <MockObjects>
          <Mock>L6.run_code() - 返回成功结果</Mock>
        </MockObjects>
        <Steps>
          <Step>构造python_repl调用请求，params={"code": "1+1"}</Step>
          <Step>调用execute("python_repl", params, ["admin"])</Step>
        </Steps>
        <Expected>
          <Check>status == "success"</Check>
          <Check>result包含"2"</Check>
          <Check>execution_time &gt; 0</Check>
        </Expected>
      </TestCase>
      
      <TestCase id="TC-L5-002" priority="critical">
        <Name>参数验证失败</Name>
        <Objective>验证无效参数会被拒绝</Objective>
        <MockObjects>
          <Mock>ParameterValidator - 返回验证失败</Mock>
        </MockObjects>
        <Steps>
          <Step>构造缺少必需字段的参数{}</Step>
          <Step>调用execute("python_repl", params, ["admin"])</Step>
        </Steps>
        <Expected>
          <Check>抛出ValidationError</Check>
          <Check>错误码为400</Check>
          <Check>错误信息说明缺少code字段</Check>
        </Expected>
      </TestCase>
      
      <TestCase id="TC-L5-003" priority="critical">
        <Name>权限不足被拒绝</Name>
        <Objective>验证权限不足的用户无法调用受限工具</Objective>
        <MockObjects>
          <Mock>PermissionChecker - 返回权限不足</Mock>
        </MockObjects>
        <Steps>
          <Step>构造guest用户的权限["guest"]</Step>
          <Step>尝试调用execute("python_repl", valid_params, ["guest"])</Step>
        </Steps>
        <Expected>
          <Check>抛出PermissionDeniedError</Check>
          <Check>错误码为403</Check>
          <Check>错误信息说明需要execute_code权限</Check>
        </Expected>
      </TestCase>
      
      <TestCase id="TC-L5-004" priority="critical">
        <Name>工具不存在</Name>
        <Objective>验证调用不存在的工具会报错</Objective>
        <MockObjects>无</MockObjects>
        <Steps>
          <Step>调用execute("nonexistent_tool", {}, ["admin"])</Step>
        </Steps>
        <Expected>
          <Check>抛出ToolNotFoundError</Check>
          <Check>错误码为404</Check>
        </Expected>
      </TestCase>
      
      <TestCase id="TC-L5-005" priority="high">
        <Name>执行超时</Name>
        <Objective>验证长时间运行的工具会被超时终止</Objective>
        <MockObjects>
          <Mock>L6.run_code() - 模拟长时间运行</Mock>
        </MockObjects>
        <Steps>
          <Step>构造无限循环的Python代码</Step>
          <Step>调用execute("python_repl", params, ["admin"], timeout=1)</Step>
        </Steps>
        <Expected>
          <Check>抛出ExecutionTimeoutError</Check>
          <Check>错误码为408</Check>
          <Check>L6进程被终止</Check>
        </Expected>
      </TestCase>
      
      <TestCase id="TC-L5-006" priority="high">
        <Name>结果格式化</Name>
        <Objective>验证执行结果会被正确格式化</Objective>
        <MockObjects>
          <Mock>L6.run_code() - 返回超长输出（&gt;10000字符）</Mock>
        </MockObjects>
        <Steps>
          <Step>构造生成超长输出的代码</Step>
          <Step>调用execute("python_repl", params, ["admin"])</Step>
        </Steps>
        <Expected>
          <Check>返回的result长度为10000字符</Check>
          <Check>metadata.truncated == true</Check>
          <Check>execution_time正确记录</Check>
        </Expected>
      </TestCase>
      
      <TestCase id="TC-L5-007" priority="medium">
        <Name>获取可用工具列表</Name>
        <Objective>验证能根据用户权限返回可用工具</Objective>
        <MockObjects>
          <Mock>ToolRegistry - 返回工具列表</Mock>
        </MockObjects>
        <Steps>
          <Step>调用get_available_tools(["user"])</Step>
        </Steps>
        <Expected>
          <Check>返回列表只包含用户有权限的工具</Check>
          <Check>不包含admin专用工具（如terminal）</Check>
          <Check>格式符合OpenAI Function Calling规范</Check>
        </Expected>
      </TestCase>
      
      <TestCase id="TC-L5-008" priority="medium">
        <Name>路径安全校验</Name>
        <Objective>验证文件操作会检查路径安全性（防止目录遍历）</Objective>
        <MockObjects>无</MockObjects>
        <Steps>
          <Step>构造恶意路径"../../../etc/passwd"</Step>
          <Step>调用execute("file_read", {"path": "../../../etc/passwd"}, ["admin"])</Step>
        </Steps>
        <Expected>
          <Check>抛出ValidationError</Check>
          <Check>错误信息说明路径不安全</Check>
        </Expected>
      </TestCase>
    </TestCases>
    
    <TDDApproach>
      <Phase name="Red">
        <Action>为工具路由、参数验证、权限检查、超时控制编写失败测试</Action>
        <Verify>测试失败，确认功能缺失</Verify>
      </Phase>
      <Phase name="Green">
        <Action>实现最简单的工具注册表和执行逻辑，Mock L6</Action>
        <Verify>所有测试通过，包括权限和验证场景</Verify>
      </Phase>
      <Phase name="Refactor">
        <Action>优化工具注册机制，添加更多内置工具</Action>
        <Verify>测试持续通过，工具扩展性良好</Verify>
      </Phase>
    </TDDApproach>
  </Testing>
  
</Layer>
