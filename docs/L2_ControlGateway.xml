<?xml version="1.0" encoding="UTF-8"?>
<!--
  L2: 控制网关层 (Control Gateway)
  创建时间: 2024
  用途: 详细定义第二层的架构、接口、耦合和测试规范
-->
<Layer id="L2" name="ControlGateway" version="1.0">
  
  <!-- ==================== 1. 结构说明 ==================== -->
  <Structure>
    <Purpose>系统的关卡，负责限流与会话状态维护</Purpose>
    
    <Responsibilities>
      <Item priority="critical">身份认证与权限校验（JWT/API Key验证）</Item>
      <Item priority="critical">会话管理（Session ID生成、会话生命周期管理）</Item>
      <Item priority="critical">历史记录检索与拼接（将历史对话注入当前上下文）</Item>
      <Item priority="high">限流控制（防止单个用户或IP的请求过载）</Item>
      <Item priority="high">上下文组装（将无状态StandardEvent转为有状态SessionContext）</Item>
      <Item priority="medium">审计日志记录（记录所有经过网关的请求）</Item>
    </Responsibilities>
    
    <Components>
      
      <Component name="SessionManager">
        <Description>会话管理器，管理会话生命周期和状态</Description>
        <Methods>
          <Method>create_session(user_id: str) -&gt; SessionContext</Method>
          <Method>get_session(session_id: str) -&gt; Optional[SessionContext]</Method>
          <Method>update_session(session_id: str, context: SessionContext) -&gt; bool</Method>
          <Method>expire_session(session_id: str) -&gt; bool</Method>
        </Methods>
        <SessionConfig>
          <TTL>3600秒（1小时）</TTL>
          <MaxHistoryLength>10轮对话</MaxHistoryLength>
          <Storage>内存（开发）/ Redis（生产）</Storage>
        </SessionConfig>
      </Component>
      
      <Component name="RateLimiter">
        <Description>限流器，防止请求过载</Description>
        <Algorithm>Token Bucket（令牌桶）</Algorithm>
        <Limits>
          <Limit scope="user">每分钟60次请求</Limit>
          <Limit scope="ip">每分钟100次请求</Limit>
          <Limit scope="global">每秒1000次请求</Limit>
        </Limits>
      </Component>
      
      <Component name="ContextAssembler">
        <Description>上下文组装器，将StandardEvent转换为SessionContext</Description>
        <Process>
          <Step>1. 获取或创建会话</Step>
          <Step>2. 从L4检索历史记录</Step>
          <Step>3. 组装滑动窗口历史</Step>
          <Step>4. 填充SessionContext对象</Step>
        </Process>
      </Component>
      
      <Component name="HistoryRetriever">
        <Description>历史记录检索器，从L4获取用户历史对话</Description>
        <Interface>调用L4.search()检索相关历史</Interface>
        <SlidingWindow>
          <MaxMessages>10</MaxMessages>
          <IncludeSystem>false</IncludeSystem>
          <Format>OpenAI消息格式[{role, content}, ...]</Format>
        </SlidingWindow>
      </Component>
    </Components>
    
    <DataFlow>
      <Step order="1">接收StandardEvent（来自L1）</Step>
      <Step order="2">RateLimiter检查是否超过请求限制</Step>
