<?xml version="1.0" encoding="UTF-8"?>
<!--
  L2: 控制网关层 (Control Gateway)
  创建时间: 2024
  用途: 详细定义第二层的架构、接口、耦合和测试规范
-->
<Layer id="L2" name="ControlGateway" version="1.0">
  
  <!-- ==================== 1. 结构说明 ==================== -->
  <Structure>
    <Purpose>系统的关卡，负责路由、鉴权、限流与会话状态维护</Purpose>
    
    <Responsibilities>
      <Item priority="critical">身份认证与权限校验（JWT/API Key验证）</Item>
      <Item priority="critical">会话管理（Session ID生成、会话生命周期管理）</Item>
      <Item priority="critical">历史记录检索与拼接（将历史对话注入当前上下文）</Item>
      <Item priority="high">限流控制（防止单个用户或IP的请求过载）</Item>
      <Item priority="high">上下文组装（将无状态StandardEvent转为有状态SessionContext）</Item>
      <Item priority="medium">审计日志记录（记录所有经过网关的请求）</Item>
    </Responsibilities>
    
    <Components>
      <Component name="Authenticator">
        <Description>认证器，验证用户身份和权限</Description>
        <Methods>
          <Method>verify_token(token: str) -&gt; bool</Method>
          <Method>verify_api_key(api_key: str) -&gt; UserInfo</Method>
        </Methods>
        <SupportedAuth>
          <Type>JWT Token (Bearer)</Type>
          <Type>API Key (Header: X-API-Key)</Type>
          <Type>Session Token (Cookie)</Type>
        </SupportedAuth>
      </Component>
      
      <Component name="SessionManager">
        <Description>会话管理器，管理会话生命周期和状态</Description>
        <Methods>
          <Method>create_session(user_id: str) -&gt; SessionContext</Method>
          <Method>get_session(session_id: str) -&gt; Optional[SessionContext]</Method>
          <Method>update_session(session_id: str, context: SessionContext) -&gt; bool</Method>
          <Method>expire_session(session_id: str) -&gt; bool</Method>
        </Methods>
        <SessionConfig>
          <TTL>3600秒（1小时）</TTL>
          <MaxHistoryLength>10轮对话</MaxHistoryLength>
          <Storage>内存（开发）/ Redis（生产）</Storage>
        </SessionConfig>
      </Component>
      
      <Component name="RateLimiter">
        <Description>限流器，防止请求过载</Description>
        <Algorithm>Token Bucket（令牌桶）</Algorithm>
        <Limits>
          <Limit scope="user">每分钟60次请求</Limit>
          <Limit scope="ip">每分钟100次请求</Limit>
          <Limit scope="global">每秒1000次请求</Limit>
        </Limits>
      </Component>
      
      <Component name="ContextAssembler">
        <Description>上下文组装器，将StandardEvent转换为SessionContext</Description>
        <Process>
          <Step>1. 获取或创建会话</Step>
          <Step>2. 从L4检索历史记录</Step>
          <Step>3. 组装滑动窗口历史</Step>
          <Step>4. 填充SessionContext对象</Step>
        </Process>
      </Component>
      
      <Component name="HistoryRetriever">
        <Description>历史记录检索器，从L4获取用户历史对话</Description>
        <Interface>调用L4.search()检索相关历史</Interface>
        <SlidingWindow>
          <MaxMessages>10</MaxMessages>
          <IncludeSystem>false</IncludeSystem>
          <Format>OpenAI消息格式[{role, content}, ...]</Format>
        </SlidingWindow>
      </Component>
    </Components>
    
    <DataFlow>
      <Step order="1">接收StandardEvent（来自L1）</Step>
      <Step order="2">RateLimiter检查是否超过请求限制</Step>
      <Step order="3">Authenticator验证用户身份和权限</Step>
      <Step order="4">SessionManager获取或创建会话</Step>
      <Step order="5">HistoryRetriever从L4检索历史记录</Step>
      <Step order="6">ContextAssembler组装SessionContext</Step>
      <Step order="7">调用L3.run(context)处理请求</Step>
      <Step order="8">接收L3返回的响应文本</Step>
      <Step order="9">调用send_response发送响应给L1</Step>
      <Step order="10">更新会话状态到L4</Step>
    </DataFlow>
  </Structure>
  
  <!-- ==================== 2. 接口规范 ==================== -->
  <Interface>
    <PrimaryMethod name="process_event">
      <Signature>
        <Input>
          <Parameter name="event" type="StandardEvent" required="true">
            <Description>来自L1的标准化事件</Description>
            <Fields>
              <Field name="channel">渠道来源</Field>
              <Field name="user_id">用户唯一标识</Field>
              <Field name="content">当前查询内容</Field>
              <Field name="timestamp">时间戳</Field>
              <Field name="metadata">附加元数据</Field>
            </Fields>
          </Parameter>
        </Input>
        
        <Output type="SessionContext">
          <Field name="session_id" type="str" required="true">
            <Description>会话唯一标识符（UUID格式）</Description>
            <Constraints>非空，格式：xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx</Constraints>
          </Field>
          <Field name="user_id" type="str" required="true">
            <Description>用户唯一标识</Description>
          </Field>
          <Field name="current_query" type="str" required="true">
            <Description>当前用户查询内容</Description>
          </Field>
          <Field name="history" type="list[dict]" required="true">
            <Description>历史对话记录的滑动窗口（OpenAI格式）</Description>
            <Example>
              <![CDATA[
              [
                {"role": "user", "content": "你好"},
                {"role": "assistant", "content": "您好！有什么可以帮助您的？"},
                {"role": "user", "content": "现在几点了？"}
              ]
              ]]>
            </Example>
          </Field>
          <Field name="user_permissions" type="list[str]" required="true">
            <Description>用户权限列表</Description>
            <ValidValues>admin, user, guest, beta_tester</ValidValues>
          </Field>
          <Field name="created_at" type="float" required="true">
            <Description>会话创建时间（Unix时间戳）</Description>
          </Field>
          <Field name="metadata" type="dict" required="false">
            <Description>会话元数据（客户端信息、地理位置等）</Description>
          </Field>
        </Output>
        
        <Exceptions>
          <Exception name="RateLimitExceeded">
            <Description>请求频率超过限制</Description>
            <ErrorCode>429</ErrorCode>
            <RetryAfter>60秒</RetryAfter>
          </Exception>
          <Exception name="AuthenticationError">
            <Description>身份认证失败</Description>
            <ErrorCode>401</ErrorCode>
          </Exception>
          <Exception name="ForbiddenError">
            <Description>用户无权限执行此操作</Description>
            <ErrorCode>403</ErrorCode>
          </Exception>
          <Exception name="SessionError">
            <Description>会话创建或检索失败</Description>
            <ErrorCode>500</ErrorCode>
          </Exception>
        </Exceptions>
      </Signature>
    </PrimaryMethod>
    
    <SecondaryMethod name="send_response">
      <Signature>
        <Input>
          <Parameter name="session_id" type="str" required="true">
            <Description>目标会话ID</Description>
          </Parameter>
          <Parameter name="text" type="str" required="true">
            <Description>响应文本内容</Description>
          </Parameter>
          <Parameter name="metadata" type="dict" required="false">
            <Description>响应元数据（格式、附件等）</Description>
          </Parameter>
        </Input>
        
        <Output type="bool">
          <Description>发送是否成功</Description>
        </Output>
      </Signature>
    </SecondaryMethod>
  </Interface>
  
  <!-- ==================== 3. 耦合关系 ==================== -->
  <Coupling>
    <Upstream>
      <Layer id="L1">用户接入层 (User Interaction)</Layer>
      <Relation>被调用（接收StandardEvent）</Relation>
      <Method>L1调用L2.process_event(event: StandardEvent)</Method>
      <DataFormat>StandardEvent对象</DataFormat>
    </Upstream>
    
    <Downstream>
      <Layer id="L3">逻辑编排层 (Orchestration)</Layer>
      <Relation>调用</Relation>
      <Method>L2调用L3.run(context: SessionContext)</Method>
      <DataFormat>SessionContext对象</DataFormat>
    </Downstream>
    
    <ExternalDependencies>
      <Layer id="L4">记忆与知识层 (Memory &amp; Knowledge)</Layer>
      <Relation>调用（HistoryRetriever）</Relation>
      <Method>调用L4.search()检索历史记录</Method>
      <Purpose>获取用户历史对话用于上下文组装</Purpose>
    </ExternalDependencies>
    
    <Dependencies>
      <Internal>
        <Dependency>models.StandardEvent - 输入数据结构</Dependency>
        <Dependency>models.SessionContext - 输出数据结构</Dependency>
        <Dependency>interfaces.MemoryInterface - L4接口抽象</Dependency>
      </Internal>
      <External>
        <Dependency>pyjwt - JWT令牌处理</Dependency>
        <Dependency>redis - 会话存储（生产环境）</Dependency>
        <Dependency>py-rate-limiter - 限流算法实现</Dependency>
      </External>
    </Dependencies>
    
    <CouplingStrength>中等耦合</CouplingStrength>
    <CouplingType>控制耦合（通过接口调用控制下层）+ 数据耦合</CouplingType>
    
    <Note>
      L2是系统的中央枢纽，与L1、L3、L4都有交互。通过依赖注入和接口抽象降低耦合度。
    </Note>
  </Coupling>
  
  <!-- ==================== 4. Mock测试规范 ==================== -->
  <Testing>
    <Strategy>Mock L4和L3，验证网关逻辑（认证、限流、会话管理）</Strategy>
    
    <TestCases>
      <TestCase id="TC-L2-001" priority="critical">
        <Name>会话创建与上下文组装</Name>
        <Objective>验证新用户首次请求时能正确创建会话并组装上下文</Objective>
        <MockObjects>
          <Mock>L4.search() - 返回空历史记录</Mock>
          <Mock>L3.run() - 返回模拟响应</Mock>
        </MockObjects>
        <Steps>
          <Step>构造包含新user_id的StandardEvent</Step>
          <Step>调用process_event(event)</Step>
          <Step>验证返回的SessionContext</Step>
        </Steps>
        <Expected>
          <Check>session_id是有效的UUID格式</Check>
          <Check>history为空列表</Check>
          <Check>current_query等于event.content</Check>
        </Expected>
      </TestCase>
      
      <TestCase id="TC-L2-002" priority="critical">
        <Name>限流触发</Name>
        <Objective>验证超过请求限制时会抛出RateLimitExceeded</Objective>
        <MockObjects>
          <Mock>RateLimiter - 模拟已达到限制</Mock>
        </MockObjects>
        <Steps>
          <Step>快速连续发送60+个请求</Step>
          <Step>调用process_event(event)</Step>
        </Steps>
        <Expected>
          <Check>第61个请求抛出RateLimitExceeded</Check>
          <Check>错误码为429</Check>
          <Check>包含Retry-After头信息</Check>
        </Expected>
      </TestCase>
      
      <TestCase id="TC-L2-003" priority="critical">
        <Name>身份认证失败</Name>
        <Objective>验证无效的身份凭证会被拒绝</Objective>
        <MockObjects>
          <Mock>Authenticator - 返回验证失败</Mock>
        </MockObjects>
        <Steps>
          <Step>构造带无效JWT token的StandardEvent</Step>
          <Step>调用process_event(event)</Step>
        </Steps>
        <Expected>
          <Check>抛出AuthenticationError</Check>
          <Check>错误码为401</Check>
        </Expected>
      </TestCase>
      
      <TestCase id="TC-L2-004" priority="high">
        <Name>历史记录检索与拼接</Name>
        <Objective>验证能正确从L4检索历史并拼接到上下文中</Objective>
        <MockObjects>
          <Mock>L4.search() - 返回模拟历史记录</Mock>
          <Mock>SessionManager - 返回现有会话</Mock>
        </MockObjects>
        <Steps>
          <Step>构造已存在session_id的StandardEvent</Step>
          <Step>配置L4.search()返回3条历史记录</Step>
          <Step>调用process_event(event)</Step>
        </Steps>
        <Expected>
          <Check>history包含3条历史记录</Check>
          <Check>历史记录格式符合OpenAI消息格式</Check>
          <Check>当前查询作为最后一条用户消息</Check>
        </Expected>
      </TestCase>
      
      <TestCase id="TC-L2-005" priority="high">
        <Name>权限验证</Name>
        <Objective>验证权限不足的用户会被拒绝访问受限功能</Objective>
        <MockObjects>
          <Mock>Authenticator - 返回guest权限用户</Mock>
        </MockObjects>
        <Steps>
          <Step>构造guest用户的StandardEvent</Step>
          <Step>请求需要admin权限的操作</Step>
          <Step>调用process_event(event)</Step>
        </Steps>
        <Expected>
          <Check>抛出ForbiddenError</Check>
          <Check>错误码为403</Check>
        </Expected>
      </TestCase>
      
      <TestCase id="TC-L2-006" priority="medium">
        <Name>响应发送</Name>
        <Objective>验证send_response能正确将响应发送回L1</Objective>
        <MockObjects>
          <Mock>L1回调接口 - 模拟响应发送</Mock>
        </MockObjects>
        <Steps>
          <Step>调用send_response(session_id, "Hello")</Step>
        </Steps>
        <Expected>
          <Check>返回True表示发送成功</Check>
          <Check>L1回调接口被调用一次</Check>
        </Expected>
      </TestCase>
    </TestCases>
    
    <TDDApproach>
      <Phase name="Red">
        <Action>为认证、限流、会话管理、历史检索编写失败测试</Action>
        <Verify>测试失败，确认功能缺失</Verify>
      </Phase>
      <Phase name="Green">
        <Action>实现最简单的网关逻辑，Mock所有依赖层</Action>
        <Verify>所有测试通过</Verify>
      </Phase>
      <Phase name="Refactor">
        <Action>优化组件结构，添加错误处理</Action>
        <Verify>测试持续通过，代码质量提升</Verify>
      </Phase>
    </TDDApproach>
  </Testing>
  
</Layer>
